{
  "name": "motiontwin-ports",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:api": "SERVE_STATIC=false node server/index.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.mjs",
    "test:api": "node --test server/*.test.mjs",
    "test:e2e": "playwright test",
    "analyze:interwheel": "node scripts/analyze-interwheel.mjs",
    "analyze:interwheel:quick": "node scripts/analyze-interwheel.mjs --quick",
    "analyze:interwheel:study": "node scripts/interwheel/study.mjs",
    "analyze:interwheel:climb": "node scripts/interwheel/validate-climb-agent.mjs",
    "analyze:interwheel:edges": "node scripts/interwheel/validate-edges.mjs",
    "capture:interwheel": "node scripts/capture-interwheel.mjs",
    "video:interwheel": "node scripts/interwheel/make-video.mjs",
    "compose:interwheel": "node scripts/interwheel/compose-short.mjs",
    "compose:wasted": "node scripts/interwheel/compose-wasted.mjs",
    "dashboard:interwheel": "node scripts/interwheel/dashboard.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "pixi.js": "8.9.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
